{
  "name": "time-in-transit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "wasm:build": "cd engine && wasm-pack build --target web --out-dir pkg",
    "wasm:build:dev": "cd engine && wasm-pack build --target web --out-dir pkg -- --features dev-placement",
    "dev": "vite",
    "build": "npm run wasm:build && tsc && vite build",
    "lint": "npm run lint:ts && npm run lint:rust",
    "lint:ts": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:rust": "cargo fmt --manifest-path engine/Cargo.toml --all && cargo clippy --manifest-path engine/Cargo.toml --all-targets --all-features -- -D warnings",
    "preview": "vite preview",
    "skills:audit": "python3 scripts/audit_skills_currentness.py",
    "skills:list": "npx skills list -a codex",
    "skills:find": "npx skills find",
    "skills:update": "npx skills update -p -y",
    "test:e2e": "npx playwright test --config tests/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config tests/playwright.config.ts --headed",
    "test:e2e:ui": "npx playwright test --config tests/playwright.config.ts --ui"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "lefthook": "^1.11.11",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^8.0.9",
    "vite-plugin-glsl": "^1.5.6",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-wasm": "^3.6.0",
    "wrangler": "^4.80.0"
  },
  "overrides": {
    "@rollup/pluginutils": "^5.3.0",
    "vite-plugin-pwa": {
      "vite": "^8.0.3"
    }
  }
}
