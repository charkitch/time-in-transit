{
  "name": "time-in-transit",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "wasm:build": "cd engine && wasm-pack build --target web --out-dir pkg",
    "wasm:build:dev": "cd engine && wasm-pack build --target web --out-dir pkg --dev",
    "dev": "vite",
    "build": "npm run wasm:build && tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.3",
    "vite-plugin-glsl": "^1.5.6",
    "vite-plugin-wasm": "^3.6.0",
    "wrangler": "^4.80.0"
  }
}
